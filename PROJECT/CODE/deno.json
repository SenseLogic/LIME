{
  "lock": false,
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check main.ts dev.ts fresh.gen.ts fresh.config.ts _middleware.ts build-scss.ts",
    "cli": "echo \"import '\\$fresh/src/dev/cli.ts'\" | deno run --unstable -A -",
    "manifest": "deno task cli manifest $(pwd)",
    "start": "deno run -A --watch=static/,routes/ dev.ts",
    "build": "deno run -A dev.ts build",
    "preview": "deno run -A main.ts",
    "update": "deno run -A -r https://fresh.deno.dev/update .",
    "build-scss": "deno run --allow-read --allow-write --allow-env build-scss.ts",
    "build-scss:watch": "deno run --allow-read --allow-write --allow-env build-scss.ts --watch",
    "dev": "deno task build-scss && deno task start"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"],
      "exclude": ["prefer-const", "no-window", "no-explicit-any"]
    }
  },
  "fmt": { "include": ["**/*.{js,jsx,ts,tsx,scss}"] },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "$std/": "https://deno.land/std@0.216.0/",
    "preact": "https://esm.sh/preact@10.22.0",
    "preact/": "https://esm.sh/preact@10.22.0/",
    "@preact/signals": "https://esm.sh/*@preact/signals@1.2.2",
    "@preact/signals-core": "https://esm.sh/*@preact/signals-core@1.5.1",
    "@supabase/ssr": "npm:@supabase/ssr@^0.8.0",
    "resend": "npm:resend@^6.7.0",
    "sharp": "npm:sharp@0.34.5",
    "stripe": "npm:stripe@^20.2.0",
    "senselogic-geo": "npm:senselogic-geo@0.1.0",
    "senselogic-gson": "npm:senselogic-gson@0.1.10",
    "senselogic-lingo": "npm:senselogic-lingo@0.1.7",
    "senselogic-opus": "npm:senselogic-opus@0.1.1",
    "senselogic-iota": "npm:senselogic-iota@0.1.0",
    "senselogic-pika": "npm:senselogic-pika@0.1.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "noImplicitAny": false
  },
  "bundle": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "sourceMap": true
  }
}
